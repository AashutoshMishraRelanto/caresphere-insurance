{
  "info": {
    "name": "Insurance Gateway API",
    "description": "API for validating patient insurance coverage and retrieving approved claim limits, intended for Salesforce integration.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"salesforce_agent\",\n  \"password\": \"sfdcpassword123\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/v1/auth/login",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "5000",
              "path": [
                "api",
                "v1",
                "auth",
                "login"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Insurance",
      "item": [
        {
          "name": "Verify Insurance",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"policyNumber\": \"POL1001\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/v1/insurance/verify",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "5000",
              "path": [
                "api",
                "v1",
                "insurance",
                "verify"
              ]
            }
          }
        }
      ]
    }
  ]
}
